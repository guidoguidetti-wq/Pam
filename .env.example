# ============================================================
#  PAM — Personal Activity Manager
#  Copia questo file in .env.local e compila i valori
# ============================================================

# ── DATABASE (Neon) ──────────────────────────────────────────
# Ottieni da: https://console.neon.tech → tuo progetto → Connection string
# Usa la stringa con "pooler" per DATABASE_URL (Prisma Accelerate / serverless)
# Usa la stringa diretta per DIRECT_URL (Prisma Migrate)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/pam?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/pam?sslmode=require"

# ── NEXTAUTH ─────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-con-stringa-casuale-sicura"
NEXTAUTH_URL="http://localhost:3000"

# ── UTENTE ADMIN (uso personale/individuale) ─────────────────
# Credenziali per il login (un solo utente, gestito via env)
PAM_ADMIN_EMAIL="guido.guidetti@softintime.com"
PAM_ADMIN_PASSWORD_HASH="$2b$10$..."  # bcrypt hash — genera con: npx bcryptjs "tuapassword"

# ── VERCEL BLOB (allegati/scontrini) ─────────────────────────
# Ottieni da: https://vercel.com → tuo progetto → Storage → Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── OPZIONALI ────────────────────────────────────────────────
# URL pubblico dell'app (necessario in produzione per NextAuth)
# NEXTAUTH_URL="https://pam.tuodominio.com"

# Dimensione massima upload allegati (default 10MB)
# MAX_UPLOAD_SIZE_MB="10"

# Valuta default per listino e report
# DEFAULT_CURRENCY="EUR"

# Ore standard di una giornata lavorativa (per calcolo residuo progetti)
# ORE_GIORNATA_DEFAULT="8"
